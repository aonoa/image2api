# Copy to .env (next to docker-compose.yml), edit, then:
#   docker compose --env-file .env up -d --build

# Frontend HTTP port exposed by Docker. Put your own reverse proxy in front of it
# for domain and TLS.
WEB_PORT=2000

# Origin served by your reverse proxy. Use http://localhost:2000 for local tests.
CORS_ORIGINS=http://localhost:2000

# Session cookie Secure flag. Use true when your reverse proxy serves HTTPS.
COOKIE_SECURE=false

APP_TITLE=ManyToken

# --- Postgres ---
POSTGRES_PASSWORD=

# --- S3 / object storage (RustFS) ---
S3_BUCKET=vivid-ai
S3_ACCESS_KEY=
S3_SECRET_KEY=
